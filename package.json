{
    "name": "n8n-nodes-hostedsms",
    "version": "1.0.2",
    "description": "n8n community node for HostedSMS.pl integration",
    "license": "MIT",
    "homepage": "https://hostedsms.pl",
    "keywords": [
        "n8n-community-node-package",
        "hostedsms"
    ],
    "author": {
        "name": "Marcin Zawadzki",
        "email": "marcinz@dcs.pl"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dcs-pl/n8n-nodes-hostedsms"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease",
        "test": "echo \"No tests specified\" && exit 0"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/HostedSmsApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/HostedSms/HostedSms.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "publishConfig": {
        "access": "public"
    }
}
